# Main LLM — DeepSeek OpenAI-compatible chat/completions.
# DEEPSEEK_API_KEY is shared with the approval classifier below.
# Optional LLM_API_KEY overrides the main-agent key only.
DEEPSEEK_API_KEY=api_key
# LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_MAX_TOKENS=8192
LLM_ENABLE_THINKING=true
# high | max  (low/medium accepted; DeepSeek maps them to high)
LLM_REASONING_EFFORT=high

# Set to true only when the main model accepts native image content blocks.
# When false, backend downgrades [image: /path] attachment markers to
# [file: /path] so the model reads them via OCR (extract_document_text).
LLM_MULTIMODAL=false

# Fast model for approval auto-mode classifier (OpenAI-compatible).
# Reuses DEEPSEEK_API_KEY. Missing key → classifier disabled; auto mode
# falls back to fast-path rules only.
APPROVAL_FAST_BASE_URL=https://api.deepseek.com
APPROVAL_FAST_MODEL=deepseek-chat
APPROVAL_FAST_MAX_TOKENS=512
APPROVAL_FAST_TIMEOUT=15

# Embedding model for RAG. Defaults to Aliyun DashScope's OpenAI-compatible
# endpoint. Any OpenAI-compatible /embeddings endpoint should also work.
# Leave EMBEDDING_API_KEY empty to disable RAG indexing/query.
EMBEDDING_API_KEY=api_key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=10
EMBEDDING_TIMEOUT=30

# RAG 索引与检索
RAG_DOCS_DIR=docs/rag_docs
RAG_DB_PATH=data/rag.db
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80

# 联网搜索（web_search 工具）。两把 key 任意配一把就能用 —— 两把都配才能走
# region=both（并发合并 + 去重）。两把都空则 web_search 工具不注册（agent 感知不到）。
# 环境变量名对齐 PentaLoom，可直接复用现有配置。
# Tavily: 海外源为主，1000 次/月免费，注册 https://app.tavily.com
# Bocha:  国内源为主（中文覆盖好），1000 次试用，注册 https://open.bochaai.com
TAVILY_API_KEY=
BOCHA_API_KEY=
