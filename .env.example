ANTHROPIC_API_KEY=api_key
ANTHROPIC_BASE_URL=https://api.novita.ai/anthropic
ANTHROPIC_MODEL=deepseek/deepseek-v4-pro
ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_ENABLE_THINKING=true
ANTHROPIC_THINKING_BUDGET=4096

# Fast model for approval auto-mode classifier.
# OpenAI-compatible API (default: DeepSeek). Optional — missing key disables
# the LLM classifier; auto mode falls back to fast-path rules only.
DEEPSEEK_API_KEY=api_key
APPROVAL_FAST_BASE_URL=https://api.deepseek.com
APPROVAL_FAST_MODEL=deepseek-chat
APPROVAL_FAST_MAX_TOKENS=512
APPROVAL_FAST_TIMEOUT=15
